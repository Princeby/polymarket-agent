# ─────────────────────────────────────────────
#  Polymarket Agent — Environment Configuration
# ─────────────────────────────────────────────

# ── Backend Selection ─────────────────────────
# Choose one: groq | openai | ollama
LLM_BACKEND=openai

# ── OpenAI ────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model options (best → cheapest):
#   gpt-4o            — Best reasoning, higher cost (~$5/1M input tokens)
#   gpt-4o-mini       — Great balance, very cheap (~$0.15/1M input tokens)  ← recommended
#   gpt-4-turbo       — Strong, moderate cost
#   gpt-3.5-turbo     — Fast and cheap, weaker reasoning
#   o3-mini           — Deep reasoning (slower, no temperature control)
#   o4-mini           — Latest reasoning model
OPENAI_MODEL=gpt-4o-mini

# Optional: Override for Azure OpenAI or a custom proxy
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2024-02-01

# ── Groq (alternative) ────────────────────────
# Get your key at: https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local, alternative) ───────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:8b

# ── Agent Settings ────────────────────────────
DRY_RUN=true
BANKROLL=100
SCAN_INTERVAL_SECONDS=300
MIN_VOLUME=10000
MIN_LIQUIDITY=1000
MIN_EDGE_THRESHOLD=0.08

# ── Polymarket (for live trading only) ────────
# POLYMARKET_API_KEY=your_key_here
