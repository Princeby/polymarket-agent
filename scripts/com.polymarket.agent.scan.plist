<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.polymarket.agent.scan</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/ogbodoebuka/Desktop/Projects/polymarket-agent/scripts/run.sh</string>
        <string>scan</string>
    </array>

    <!-- Run every 30 minutes -->
    <key>StartInterval</key>
    <integer>1800</integer>

    <!-- Also run immediately when loaded -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Logging -->
    <key>StandardOutPath</key>
    <string>/Users/ogbodoebuka/Desktop/Projects/polymarket-agent/data/logs/launchd_scan.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ogbodoebuka/Desktop/Projects/polymarket-agent/data/logs/launchd_scan.log</string>
</dict>
</plist>
