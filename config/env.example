# ─────────────────────────────────────────────────────────
#  Polymarket Agent — Environment Configuration
#  Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── Backend Selection ──────────────────────────────────────
LLM_BACKEND=groq

# ── Groq ───────────────────────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Telegram ───────────────────────────────────────────────
# Create a bot at https://t.me/BotFather and paste the token here
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Your personal Telegram chat ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=987654321

# ── Railway Webhook ────────────────────────────────────────
# Set this to your Railway deployment URL AFTER first deploy.
# Format: https://your-app-name.railway.app
# Leave blank for local development (falls back to polling).
WEBHOOK_URL=https://your-app-name.railway.app

# ── Agent Settings ─────────────────────────────────────────
# Set DRY_RUN=false to place real orders (use /live on in Telegram instead)
DRY_RUN=true

BANKROLL=100
SCAN_INTERVAL_MINUTES=30
MAX_MARKETS_PER_SCAN=10
MIN_VOLUME=10000
MIN_LIQUIDITY=1000
MIN_EDGE_THRESHOLD=0.08

# ── Polymarket Live Trading ────────────────────────────────
# Your wallet's private key (hex, without 0x prefix).
# NEVER commit this to git.
POLYMARKET_PRIVATE_KEY=your_wallet_private_key_here

# Derived from POLYMARKET_PRIVATE_KEY — run derive_creds.py once to get these
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── Claude (for self-improvement) ─────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
