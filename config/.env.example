# ─────────────────────────────────────────────
#  Polymarket Agent — Environment Configuration
# ─────────────────────────────────────────────

# ── Backend Selection ─────────────────────────
LLM_BACKEND=groq

# ── Groq ──────────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# Set this to your finetuned model ID from the Groq console
# (visible under "Fine-tuned Models" after upload completes)
# e.g. GROQ_MODEL=ft:llama-3.3-70b-versatile:your-org:my-model:abc123
GROQ_MODEL=ft:YOUR_FINETUNED_MODEL_ID_HERE

# ── Agent Settings ────────────────────────────
# Set DRY_RUN=false to place real orders on Polymarket
DRY_RUN=false

BANKROLL=100
SCAN_INTERVAL_SECONDS=300
MIN_VOLUME=10000
MIN_LIQUIDITY=1000
MIN_EDGE_THRESHOLD=0.08

# ── Polymarket Live Trading ────────────────────
# Your wallet's private key (hex, without 0x prefix).
# This wallet must hold USDC on Polygon and have approved the Polymarket contract.
# NEVER commit this to git.
POLYMARKET_PRIVATE_KEY=your_wallet_private_key_here

# API credentials — derived automatically from POLYMARKET_PRIVATE_KEY on first run.
# After the first run, copy the logged values here to skip re-derivation.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
